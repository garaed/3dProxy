#!/bin/bash
# =============================================================
# 3proxy auto-installer for Debian 12
# Usage: curl -sSL https://raw.githubusercontent.com/YOUR/REPO/main/3proxy-install.sh | bash
# Output: login:pass@ip:port
# =============================================================

set -e

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log()  { echo -e "${GREEN}[+]${NC} $1"; }
warn() { echo -e "${YELLOW}[!]${NC} $1"; }
die()  { echo -e "${RED}[✗]${NC} $1"; exit 1; }

# --- Проверка root ---
[ "$EUID" -ne 0 ] && die "Запустите скрипт от root"

# --- Количество прокси ---
echo ""
echo -e "${CYAN}Сколько SOCKS5 прокси создать? [по умолчанию: 1]:${NC} "
read -r -t 10 PROXY_COUNT || true
PROXY_COUNT=$(echo "$PROXY_COUNT" | tr -dc '0-9')
[ -z "$PROXY_COUNT" ] || [ "$PROXY_COUNT" -lt 1 ] && PROXY_COUNT=1
log "Будет создано прокси: $PROXY_COUNT"

# --- Начальный порт ---
START_PORT=1080

# --- Получение внешнего IP ---
log "Определение внешнего IP..."
SERVER_IP=$(curl -s --max-time 5 https://ifconfig.me 2>/dev/null || \
            curl -s --max-time 5 https://api.ipify.org 2>/dev/null || \
            curl -s --max-time 5 https://icanhazip.com 2>/dev/null)
[ -z "$SERVER_IP" ] && die "Не удалось определить внешний IP"
log "IP сервера: $SERVER_IP"

# --- Установка зависимостей ---
log "Обновление пакетов..."
apt-get update -qq

log "Установка зависимостей..."
apt-get install -y -qq build-essential git curl > /dev/null 2>&1

# --- Установка 3proxy ---
if ! command -v 3proxy &>/dev/null; then
    log "Клонирование 3proxy..."
    cd /usr/local/src
    [ -d "3proxy" ] && rm -rf 3proxy
    git clone --quiet https://github.com/3proxy/3proxy.git
    cd 3proxy
    log "Компиляция 3proxy..."
    make -f Makefile.Linux > /dev/null 2>&1
    make -f Makefile.Linux install > /dev/null 2>&1
    log "3proxy установлен"
else
    log "3proxy уже установлен, пропускаем"
fi

PROXY_BIN=$(command -v 3proxy)
[ -z "$PROXY_BIN" ] && die "Бинарник 3proxy не найден"

# --- Генерация пользователей ---
log "Генерация учётных данных..."
mkdir -p /etc/3proxy

USERS_LINE=""
declare -a PROXY_LIST

for i in $(seq 1 "$PROXY_COUNT"); do
    UNAME="user$(tr -dc 'a-z0-9' </dev/urandom | head -c 6)"
    UPASS=$(tr -dc 'A-Za-z0-9' </dev/urandom | head -c 16)
    PORT=$((START_PORT + i - 1))
    PROXY_LIST+=("${UNAME}:${UPASS}:${PORT}")
    USERS_LINE="${USERS_LINE} ${UNAME}:CL:${UPASS}"
done

# --- Конфигурация ---
log "Создание конфигурации..."

cat > /etc/3proxy/3proxy.cfg << EOF
log /var/log/3proxy.log D
logformat "- +_L%t.%. %N.%p %E %U %C:%c %R:%r %O %I %h %T"

nserver 8.8.8.8
nserver 1.1.1.1

setgid 65534
setuid 65534

users${USERS_LINE}

EOF

for entry in "${PROXY_LIST[@]}"; do
    UNAME=$(echo "$entry" | cut -d: -f1)
    PORT=$(echo  "$entry" | cut -d: -f3)
    cat >> /etc/3proxy/3proxy.cfg << EOF
auth strong
allow ${UNAME}
socks -p${PORT}

EOF
done

# --- Systemd unit ---
log "Создание systemd сервиса..."
cat > /etc/systemd/system/3proxy.service << EOF
[Unit]
Description=3proxy Proxy Server
After=network.target

[Service]
Type=simple
ExecStart=${PROXY_BIN} /etc/3proxy/3proxy.cfg
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

# --- Запуск ---
log "Запуск сервиса..."
systemctl daemon-reload
systemctl enable 3proxy > /dev/null 2>&1
systemctl restart 3proxy
sleep 2

systemctl is-active --quiet 3proxy || die "Не удалось запустить 3proxy. Проверьте: journalctl -u 3proxy"
log "3proxy запущен успешно"

# --- Открытие портов ---

# ufw (если активен)
if command -v ufw &>/dev/null && ufw status 2>/dev/null | grep -q "Status: active"; then
    log "ufw активен — открываем порты..."
    for entry in "${PROXY_LIST[@]}"; do
        PORT=$(echo "$entry" | cut -d: -f3)
        ufw allow "$PORT"/tcp > /dev/null 2>&1
    done
    ufw reload > /dev/null 2>&1
    log "Порты открыты в ufw"
else
    warn "ufw не активен — пропускаем"
fi

# iptables (всегда применяем)
log "Добавление правил iptables..."
for entry in "${PROXY_LIST[@]}"; do
    PORT=$(echo "$entry" | cut -d: -f3)
    # Добавляем только если правило ещё не существует
    iptables -C INPUT -p tcp --dport "$PORT" -j ACCEPT 2>/dev/null || \
        iptables -A INPUT -p tcp --dport "$PORT" -j ACCEPT
done

# Сохраняем правила iptables
if command -v iptables-save &>/dev/null; then
    iptables-save > /etc/iptables/rules.v4 2>/dev/null || \
    iptables-save > /etc/iptables.rules 2>/dev/null || \
    warn "Не удалось сохранить правила iptables — сохраните вручную"
    log "Правила iptables сохранены"
fi

# --- Результат ---
echo ""
echo -e "${GREEN}=================================================${NC}"
echo -e "${GREEN}   ✓ 3proxy установлен! Ваши прокси:${NC}"
echo -e "${GREEN}=================================================${NC}"
echo ""

for entry in "${PROXY_LIST[@]}"; do
    UNAME=$(echo "$entry" | cut -d: -f1)
    UPASS=$(echo "$entry" | cut -d: -f2)
    PORT=$(echo  "$entry" | cut -d: -f3)
    echo -e "  ${YELLOW}${UNAME}:${UPASS}@${SERVER_IP}:${PORT}${NC}"
done

echo ""
echo -e "${GREEN}=================================================${NC}"
